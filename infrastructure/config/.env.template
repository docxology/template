# Environment variables for my-awesome-project
# Copy this to .env and edit as needed
#
# NOTE: See manuscript/config.yaml.example for YAML configuration (recommended method)
# Priority: Environment variables OVERRIDE manuscript/config.yaml values
# For full configuration details, see AGENTS.md#configuration-system

# Project metadata (can override defaults from rename_project.sh)
AUTHOR_NAME="Dr. Jane Smith"
AUTHOR_ORCID="0000-0000-0000-0000"
AUTHOR_EMAIL="jane.smith@university.edu"
DOI="10.5281/zenodo.12345678"
PROJECT_TITLE="my-awesome-project"

# Development settings
LOG_LEVEL=1
MPLBACKEND=Agg

# Deep research providers (optional)
# OpenAI API keys: https://platform.openai.com/api-keys
# Gemini API keys: https://ai.google.dev/gemini-api/docs/api-key
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_DEEP_RESEARCH_MODEL=o3-deep-research
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_DEEP_RESEARCH_AGENT=deep-research-preview-04-2026
#
# Agent operating notes for computer use:
# 1. Open the provider console:
#    - OpenAI: https://platform.openai.com/api-keys
#    - Gemini: https://ai.google.dev/gemini-api/docs/api-key
# 2. Create a new API key for the provider.
# 3. Copy the key into the matching variable in the repo root .env file.
# 4. Do not paste secrets into tracked files, commit history, or chat.
# 5. Keep provider overrides only when you need a non-default model or agent.

# Publishing (production Zenodo — never commit real tokens)
# ZENODO_PROD_TOKEN=your_zenodo_pat_here
# ZENODO_SANDBOX_TOKEN=your_sandbox_pat_here
# GITHUB_TOKEN=your_github_pat_here
# GITHUB_REPO=owner/repo

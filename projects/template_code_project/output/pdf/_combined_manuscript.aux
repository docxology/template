\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Objective value \(f(x_k)=\tfrac  {1}{2}x_k^2 - x_k\) versus iteration \(k\) for gradient descent at six step sizes (legend colours follow the agency taxonomy in sec.~\ref {sec:methodology}: blue = conservative, green = near-optimal, orange = aggressive, red = divergent). Trajectories are produced by \texttt {simulate\_trajectory()} in \texttt {src/optimizer.py}, which calls the same \texttt {gradient\_descent()} used in tbl.~\ref {tbl:opt_results}; the upper bound on the y-axis clips the divergent \(\mitalpha =2.5\) curve so that stable trajectories remain visible. Dashed grey reference line marks the analytic optimum \(f(x^\ast )=-0.5\). Fastest configuration in this experiment: \(\mitalpha =1.0\) converges in 1 iteration(s).}}{12}{figure.caption.2}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:convergence}{{1}{12}{Objective value \(f(x_k)=\tfrac {1}{2}x_k^2 - x_k\) versus iteration \(k\) for gradient descent at six step sizes (legend colours follow the agency taxonomy in sec.~\ref {sec:methodology}: blue = conservative, green = near-optimal, orange = aggressive, red = divergent). Trajectories are produced by \protect \texttt {simulate\_trajectory()} in \protect \texttt {src/optimizer.py}, which calls the same \protect \texttt {gradient\_descent()} used in tbl.~\ref {tbl:opt_results}; the upper bound on the y-axis clips the divergent \(\alpha =2.5\) curve so that stable trajectories remain visible. Dashed grey reference line marks the analytic optimum \(f(x^\ast )=-0.5\). Fastest configuration in this experiment: \(\alpha =1.0\) converges in 1 iteration(s)}{figure.caption.2}{}}
\newlabel{fig:convergence@cref}{{[figure][1][]1}{[1][10][]12}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Sensitivity sweep produced by \texttt {generate\_step\_size\_sensitivity\_plot()} over an independent dense grid \(\mitalpha \in [0.005, 0.4]\) (15 points), distinct from the discrete \texttt {experiment.step\_sizes} used elsewhere in this section. Left: iterations to convergence on log--log axes --- the curve drops sharply from 501 iterations at the smallest \(\mitalpha \) (the \texttt {max\_iterations} cap in this sub-experiment) to 38 iterations at \(\mitalpha =0.4\), illustrating the geometric speedup as \(\mitrho (\mitalpha )=|1-\mitalpha |\) shrinks. Right: final \(f(x)\) versus \(\mitalpha \) with horizontal reference lines at \(f(x_0)=0\) (initial) and \(f(x^\ast )=-0.5\) (analytic optimum); every \(\mitalpha \) in this stable window lands on the optimum.}}{13}{figure.caption.3}\protected@file@percent }
\newlabel{fig:step_sensitivity}{{2}{13}{Sensitivity sweep produced by \protect \texttt {generate\_step\_size\_sensitivity\_plot()} over an independent dense grid \(\alpha \in [0.005, 0.4]\) (15 points), distinct from the discrete \protect \texttt {experiment.step\_sizes} used elsewhere in this section. Left: iterations to convergence on log--log axes --- the curve drops sharply from 501 iterations at the smallest \(\alpha \) (the \protect \texttt {max\_iterations} cap in this sub-experiment) to 38 iterations at \(\alpha =0.4\), illustrating the geometric speedup as \(\rho (\alpha )=|1-\alpha |\) shrinks. Right: final \(f(x)\) versus \(\alpha \) with horizontal reference lines at \(f(x_0)=0\) (initial) and \(f(x^\ast )=-0.5\) (analytic optimum); every \(\alpha \) in this stable window lands on the optimum}{figure.caption.3}{}}
\newlabel{fig:step_sensitivity@cref}{{[figure][2][]2}{[1][10][]13}{}{}{}}

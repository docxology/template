\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Gradient descent convergence trajectories for four step sizes (\(\mitalpha = 0.01, 0.05, 0.1, 0.2\)) on the quadratic \(f(x) = \frac  {1}{2}x^2 - x\). Larger \(\mitalpha ) values reach the analytical minimum \(f(x^*) = -0.5\) in fewer iterations, with \(\mitalpha = 0.2\) converging in \$\sim \$9 iterations versus \$\sim \$165 for \(\mitalpha = 0.01\).}}{8}{figure.1}\protected@file@percent }
\newlabel{fig:convergence}{{1}{8}{Gradient descent convergence trajectories for four step sizes (\(\alpha = 0.01, 0.05, 0.1, 0.2\)) on the quadratic \(f(x) = \frac {1}{2}x^2 - x\). Larger \(\alpha ) values reach the analytical minimum \(f(x^*) = -0.5\) in fewer iterations, with \(\alpha = 0.2\) converging in \$\sim \$9 iterations versus \$\sim \$165 for \(\alpha = 0.01\)}{figure.1}{}}
\newlabel{fig:convergence@cref}{{[figure][1][]1}{[1][8][]8}{}{}{}}

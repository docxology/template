\newlabel{fig:convergence}{{1}{1}{Figure: Gradient descent on \(f(x)=\tfrac {1}{2}x^2-x\) for \(\alpha \in \{0.01, 0.1, 0.5, 1.0, 1.5, 2.5\}\). Trajectories use \protect \texttt {simulate\_trajectory()} (same \protect \texttt {gradient\_descent()} as the table); objectives are clipped for plotting when \(\alpha \) is unstable. Reference line: \(f(x^\ast )=-0.5\). Best iteration count in this experiment: 1 at \(\alpha =1.0\)}{fig:convergence}{}}
\@writefile{snm}{\beamer@slide {fig:convergence}{1}}
\newlabel{step-size-sensitivity-analysis}{{1}{1}{}{step-size-sensitivity-analysis}{}}
\@writefile{snm}{\beamer@slide {step-size-sensitivity-analysis}{1}}
\newlabel{fig:step_sensitivity}{{2}{1}{Figure: Sensitivity sweep (independent dense grid \(\alpha \in [0.005,0.4]\)) for the same quadratic. Left: log--log iterations vs \(\alpha \) (longer runs for small \(\alpha \)). Right: final \(f(x)\) vs \(\alpha \) with horizontal lines at \(f(x_0)=0\) and \(f(x^\ast )=-0.5\). This panel illustrates the continuous trade-off between stability and speed; it is not limited to the discrete \protect \texttt {experiment.step\_sizes} grid}{fig:step_sensitivity}{}}
\@writefile{snm}{\beamer@slide {fig:step_sensitivity}{1}}

\@writefile{lot}{\contentsline {table}{\numberline {8}{\ignorespaces Pairwise Welch's $t$-test comparisons of mean ambiguity scores between Ento-Linguistic domains. Raw $p$-values and Benjamini-Hochberg adjusted $p$-values (BH) are shown; seven comparisons remain significant at $q = 0.05$ after correction. The one-way ANOVA across all six domains yields $F(5, 217) = 8.74$, $p < 0.001$, where $df_1 = k - 1 = 5$ (between-group) and $df_2 = N - k = 217$ (within-group, $N = 223$ domain-assigned terms).}}{43}{table.caption.20}\protected@file@percent }
\newlabel{tab:pairwise_domain}{{8}{43}{Pairwise Welch's $t$-test comparisons of mean ambiguity scores between Ento-Linguistic domains. Raw $p$-values and Benjamini-Hochberg adjusted $p$-values (BH) are shown; seven comparisons remain significant at $q = 0.05$ after correction. The one-way ANOVA across all six domains yields $F(5, 217) = 8.74$, $p < 0.001$, where $df_1 = k - 1 = 5$ (between-group) and $df_2 = N - k = 217$ (within-group, $N = 223$ domain-assigned terms)}{table.caption.20}{}}
\newlabel{tab:pairwise_domain@cref}{{[table][8][]8}{[1][43][]43}{}{}{}}

\@writefile{lot}{\contentsline {table}{\numberline {9}{\ignorespaces CACE dimension scores for representative entomological terms. Anthropomorphic terms (queen, worker, slave, caste, soldier) consistently score lower than functional alternatives (italicized). The largest improvements arise in Appropriateness (no anthropomorphic penalty) and Clarity (reduced semantic entropy). Non-anthropomorphic technical terms (haplodiploidy, trophallaxis) score highest on Clarity due to unambiguous, single-sense usage.}}{44}{table.caption.21}\protected@file@percent }
\newlabel{tab:cace_full}{{9}{44}{CACE dimension scores for representative entomological terms. Anthropomorphic terms (queen, worker, slave, caste, soldier) consistently score lower than functional alternatives (italicized). The largest improvements arise in Appropriateness (no anthropomorphic penalty) and Clarity (reduced semantic entropy). Non-anthropomorphic technical terms (haplodiploidy, trophallaxis) score highest on Clarity due to unambiguous, single-sense usage}{table.caption.21}{}}
\newlabel{tab:cace_full@cref}{{[table][9][]9}{[1][43][]44}{}{}{}}
\@writefile{lot}{\contentsline {table}{\numberline {10}{\ignorespaces Distribution of semantic entropy $H(t)$ across Ento-Linguistic domains. High-entropy terms are those exceeding the $H > 2.0$ bits threshold. Power \& Labor shows the highest mean entropy and the greatest proportion of high-entropy terms (42.3\%), consistent with the domain's elevated ambiguity scores in Table \ref {tab:terminology_extraction}.}}{44}{table.caption.22}\protected@file@percent }
\newlabel{tab:entropy_distribution}{{10}{44}{Distribution of semantic entropy $H(t)$ across Ento-Linguistic domains. High-entropy terms are those exceeding the $H > 2.0$ bits threshold. Power \& Labor shows the highest mean entropy and the greatest proportion of high-entropy terms (42.3\%), consistent with the domain's elevated ambiguity scores in Table \ref {tab:terminology_extraction}}{table.caption.22}{}}
\newlabel{tab:entropy_distribution@cref}{{[table][10][]10}{[1][43][]44}{}{}{}}

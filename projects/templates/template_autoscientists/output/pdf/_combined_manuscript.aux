\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Reported versus clean (ground-truth) champion metric for the full configuration and each single-mechanism ablation. A reported-greater-than-clean gap is accepted noise. Removing noise-band confirmation inflates the gap roughly thirteenfold while the clean metric is unchanged. Produced by \texttt {run\_ablation.py}.}}{7}{figure.caption.3}\protected@file@percent }
\newlabel{fig:ablation}{{2}{7}{Reported versus clean (ground-truth) champion metric for the full configuration and each single-mechanism ablation. A reported-greater-than-clean gap is accepted noise. Removing noise-band confirmation inflates the gap roughly thirteenfold while the clean metric is unchanged. Produced by \protect \texttt {run\_ablation.py}}{figure.caption.3}{}}
\newlabel{fig:ablation@cref}{{[figure][2][]2}{[1][7][]7}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Experiments used and redundant re-probes of retired directions per configuration. Only the dead-end-registry ablation changes the profile: without the registry the search wastes \(36\) experiments re-exploring known-dead directions and never halts early. Produced by \texttt {run\_ablation.py}.}}{8}{figure.caption.4}\protected@file@percent }
\newlabel{fig:ablation_efficiency}{{3}{8}{Experiments used and redundant re-probes of retired directions per configuration. Only the dead-end-registry ablation changes the profile: without the registry the search wastes \(36\) experiments re-exploring known-dead directions and never halts early. Produced by \protect \texttt {run\_ablation.py}}{figure.caption.4}{}}
\newlabel{fig:ablation_efficiency@cref}{{[figure][3][]3}{[1][8][]8}{}{}{}}

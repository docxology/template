# Formal Configuration Template
# Copy this file to config.yaml and customize for your project
# This file serves as a meta-artifact linking the prose of the manuscript to the execution
# layer. It is loaded by `yaml.safe_load` inside `infrastructure/rendering/_pdf_combined_renderer.py`
# (manuscript metadata).

# Consumed by: `infrastructure/rendering/pdf_renderer.py`
paper:
  # Follow the RASP standard: titles must be objective and descriptive
  title: "Your Strongly-Typed Multiagent Research Title"
  subtitle: "Optional Subtitle"
  version: "1.0"
  date: ""  # Auto-generated by `infrastructure/validation/output/validator.py` if empty
  # Optional title-page cover art — regenerate the committed PNG with
  # `scripts/zz_generate_cover_art.py` (see src cover_art.require_cover_art).
  # cover:
  #   image: "figures/cover_colony.png"

# Consumed by: `infrastructure.publishing.extract_publication_metadata` (in `infrastructure/publishing/metadata.py`)
authors:
  - name: "Your Name"
    orcid: "0000-0000-0000-0000"  # Get from https://orcid.org/
    email: "your.email@university.edu"
    affiliation: "Your University"
    corresponding: true

# Optional: Multiple authors
#  - name: "Co-Author Name"
#    orcid: "0000-0000-0000-0000"
#    email: "coauthor@university.edu"
#    affiliation: "Co-Author University"
#    corresponding: false

# Release workflow (Zenodo + GitHub): see docs/guides/publishing-guide.md and
# docs/guides/zenodo-doi-strategy.md for the split concept/version DOI layout.

# Consumed by: `infrastructure.publishing.publish_to_zenodo` (in `infrastructure/publishing/platforms.py`)
publication:
  doi: ""  # Concept DOI — stable citation; PDF cover and CITATION.cff use this field only
  version_doi: ""  # Latest Zenodo version DOI; updated by publish_project_release.py when split layout is used
  version_record: ""  # https://zenodo.org/records/{id} for the latest deposit
  github_repository: ""  # Pre-release bookends; e.g. docxology/template_formal
  transmission_bookends:
    enabled: false
    max_prior_releases: 5
    show_steganography: true
  deposit_filename:
    enabled: true
    topic: ""  # optional; default = first significant title word
  journal: ""
  volume: ""
  pages: ""
  year: ""

keywords:
  - "strongly typed programming"
  - "session types"
  - "algebraic data types"
  - "category theory"
  - "active inference"
  - "multiagent systems"

metadata:
  license: "Apache-2.0"
  language: "en"

steganography:
  enabled: true
  overlays_enabled: true
  barcodes_enabled: true
  metadata_enabled: true
  hashing_enabled: true
  encryption_enabled: false
  overlay_mode: "text"
  overlay_text: "CONFIDENTIAL"

# Consumed by: `infrastructure.llm.LLMClient` (in `infrastructure/llm/core/client.py`)
llm:
  reviews:
    enabled: false  # Set to true to enable LLM-powered reviews
    types:
      - executive_summary  # Default
      # - quality_review
      # - methodology_review
      # - improvement_suggestions
  translations:
    enabled: false  # Set to true to enable automated translations
    languages:
      - zh  # Default: Chinese Simplified

# Consumed by: `infrastructure/reporting/pipeline_report_model.py` and CI/CD gates
testing:
  max_test_failures: 0
  max_infra_test_failures: 0
  max_project_test_failures: 0

render:
  formats:
    pdf: true
    html: true
    slides: true
    docx: false
    epub: false

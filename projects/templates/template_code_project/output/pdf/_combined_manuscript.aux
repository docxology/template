\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Absolute objective error \(|f(x_k)-f(x^\ast )|\) versus iteration on a logarithmic y-axis, generated by \breaktt {generate\_convergence\_rate\_plot()}. Stable step sizes produce straight lines whose slopes equal \(2\log _{10}\mitrho (\mitalpha )\) (per eq.~\ref {eq:convergence_bound}); \(\mitalpha =1.0\) (\(\mitrho =0\)) collapses to the optimum in one step (vertical green line at \(k=1\)); \(\mitalpha =1.5\) (orange) descends fastest among the multi-step contractions because \(\mitrho =0.5\); the divergent \(\mitalpha =2.5\) curve (red) climbs upward at slope \(2\log _{10}(1.5)\). Horizontal dashed line marks the gradient-norm tolerance \(\mitvarepsilon = 10^{-8}\) read from \breaktt {experiment.convergence\_tolerance}.}}{11}{figure.caption.10}\protected@file@percent }
\newlabel{fig:convergence_rate}{{5}{11}{Absolute objective error \(|f(x_k)-f(x^\ast )|\) versus iteration on a logarithmic y-axis, generated by \protect \breaktt {generate\_convergence\_rate\_plot()}. Stable step sizes produce straight lines whose slopes equal \(2\log _{10}\rho (\alpha )\) (per eq.~\ref {eq:convergence_bound}); \(\alpha =1.0\) (\(\rho =0\)) collapses to the optimum in one step (vertical green line at \(k=1\)); \(\alpha =1.5\) (orange) descends fastest among the multi-step contractions because \(\rho =0.5\); the divergent \(\alpha =2.5\) curve (red) climbs upward at slope \(2\log _{10}(1.5)\). Horizontal dashed line marks the gradient-norm tolerance \(\varepsilon = 10^{-8}\) read from \protect \breaktt {experiment.convergence\_tolerance}}{figure.caption.10}{}}
\newlabel{fig:convergence_rate@cref}{{[figure][5][]5}{[1][10][]11}{}{}{}}

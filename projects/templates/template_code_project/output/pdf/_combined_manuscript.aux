\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Objective value \(f(x_k)=\tfrac  {1}{2}x_k^2 - x_k\) versus iteration \(k\) for gradient descent at six step sizes (legend colours follow the agency taxonomy in sec.~\ref {sec:methodology}: blue = conservative, green = near-optimal, orange = aggressive, red = divergent). Trajectories are produced by \breaktt {simulate\_trajectory()} in \breaktt {src/optimizer.py}, which calls the same \breaktt {gradient\_descent()} used in tbl.~\ref {tbl:opt_results}; the upper bound on the y-axis clips the divergent \(\mitalpha =2.5\) curve so that stable trajectories remain visible. Dashed grey reference line marks the analytic optimum \(f(x^\ast )=-0.5\). Fastest configuration in this experiment: \(\mitalpha =1.0\) converges in 1 iteration(s).}}{9}{figure.caption.8}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:convergence}{{3}{9}{Objective value \(f(x_k)=\tfrac {1}{2}x_k^2 - x_k\) versus iteration \(k\) for gradient descent at six step sizes (legend colours follow the agency taxonomy in sec.~\ref {sec:methodology}: blue = conservative, green = near-optimal, orange = aggressive, red = divergent). Trajectories are produced by \protect \breaktt {simulate\_trajectory()} in \protect \breaktt {src/optimizer.py}, which calls the same \protect \breaktt {gradient\_descent()} used in tbl.~\ref {tbl:opt_results}; the upper bound on the y-axis clips the divergent \(\alpha =2.5\) curve so that stable trajectories remain visible. Dashed grey reference line marks the analytic optimum \(f(x^\ast )=-0.5\). Fastest configuration in this experiment: \(\alpha =1.0\) converges in 1 iteration(s)}{figure.caption.8}{}}
\newlabel{fig:convergence@cref}{{[figure][3][]3}{[1][9][]9}{}{}{}}

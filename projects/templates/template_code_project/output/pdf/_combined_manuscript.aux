\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Four-panel diagnostic from \breaktt {generate\_complexity\_visualization()}. \textbf  {Top left}: bars give the empirical iteration count per configured \(\mitalpha \), coloured by agency category; \(\mitalpha =1.0\) achieves the global minimum of 1 step(s), while \(\mitalpha =0.01\) and \(\mitalpha =2.5\) both saturate at the iteration cap \(N_{\max }=1000\) (slow convergence and divergence respectively). \textbf  {Top right}: \(\log _{10}|f(x)-f(x^\ast )|\) at termination; the four converged rows reach \(\approx 10^{-16}\) (machine precision) while \(\mitalpha =0.01\) stops near \(10^{-9}\) at the cap. Dashed reference at \(\log _{10}\mitvarepsilon \) for \(\mitvarepsilon =\) \breaktt {experiment.convergence\_tolerance}. \textbf  {Bottom left}: empirical iterations (solid) versus the smooth proxy \(1/(2\mitalpha (1-\mitalpha ))\) (dashed) on log axes --- a shape comparison, not a tight count prediction for every \(\mitalpha \). \textbf  {Bottom right}: per-step error contraction factor \(\mitrho =|1-\mitalpha |\) from the unit-Hessian linear recurrence (eq.~\ref {eq:scalar_linear_update}); the dashed reference at \(\mitrho =1\) separates stable bars (left of it) from divergent ones (right).}}{13}{figure.caption.11}\protected@file@percent }
\newlabel{fig:complexity}{{6}{13}{Four-panel diagnostic from \protect \breaktt {generate\_complexity\_visualization()}. \textbf {Top left}: bars give the empirical iteration count per configured \(\alpha \), coloured by agency category; \(\alpha =1.0\) achieves the global minimum of 1 step(s), while \(\alpha =0.01\) and \(\alpha =2.5\) both saturate at the iteration cap \(N_{\max }=1000\) (slow convergence and divergence respectively). \textbf {Top right}: \(\log _{10}|f(x)-f(x^\ast )|\) at termination; the four converged rows reach \(\approx 10^{-16}\) (machine precision) while \(\alpha =0.01\) stops near \(10^{-9}\) at the cap. Dashed reference at \(\log _{10}\varepsilon \) for \(\varepsilon =\) \protect \breaktt {experiment.convergence\_tolerance}. \textbf {Bottom left}: empirical iterations (solid) versus the smooth proxy \(1/(2\alpha (1-\alpha ))\) (dashed) on log axes --- a shape comparison, not a tight count prediction for every \(\alpha \). \textbf {Bottom right}: per-step error contraction factor \(\rho =|1-\alpha |\) from the unit-Hessian linear recurrence (eq.~\ref {eq:scalar_linear_update}); the dashed reference at \(\rho =1\) separates stable bars (left of it) from divergent ones (right)}{figure.caption.11}{}}
\newlabel{fig:complexity@cref}{{[figure][6][]6}{[1][12][]13}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Deterministic dimensional benchmark from \breaktt {generate\_benchmark\_visualization()}. Dimensions \(d \in \{1, 2, 5, 10, 20, 50\}\) run on identity-Hessian quadratics with \(\mitalpha =0.1\) and gradient tolerance \(10^{-10}\). \textbf  {Left}: the implementation-independent work proxy \(d \times \text  {iterations}\), proportional to scalar elements processed by the dense matrix-vector update. \textbf  {Right}: exact iterations to convergence. Wall-clock microseconds are intentionally excluded because they vary with hardware and host load. The similar iteration counts are expected because \(\mitkappa (I_d)=1\) and the contraction factor \(\mitrho =|1-\mitalpha |=0.9\) is dimension-independent.}}{14}{figure.caption.12}\protected@file@percent }
\newlabel{fig:benchmark}{{7}{14}{Deterministic dimensional benchmark from \protect \breaktt {generate\_benchmark\_visualization()}. Dimensions \(d \in \{1, 2, 5, 10, 20, 50\}\) run on identity-Hessian quadratics with \(\alpha =0.1\) and gradient tolerance \(10^{-10}\). \textbf {Left}: the implementation-independent work proxy \(d \times \text {iterations}\), proportional to scalar elements processed by the dense matrix-vector update. \textbf {Right}: exact iterations to convergence. Wall-clock microseconds are intentionally excluded because they vary with hardware and host load. The similar iteration counts are expected because \(\kappa (I_d)=1\) and the contraction factor \(\rho =|1-\alpha |=0.9\) is dimension-independent}{figure.caption.12}{}}
\newlabel{fig:benchmark@cref}{{[figure][7][]7}{[1][12][]14}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Numerical stability heatmap from \breaktt {generate\_stability\_visualization()}. Each cell shows \(\log _{10}|f(x)-f(x^\ast )|\) at termination for one (starting point \(x_0\), step size \(\mitalpha \)) combination, evaluated by \breaktt {gradient\_descent()} over the 8-by-6 grid (48 cells). The leftmost column (\(\mitalpha =0.01\), conservative) reaches only \(10^{-6}\) to \(10^{-9}\) within the iteration cap, while every other column saturates at machine precision (\(10^{-16}\)) regardless of how far \(x_0\) starts from the optimum (range \([-50, 50]\)). The right panel summarises this uniformity as the aggregate stability score of 1.00/1.00 returned by \breaktt {infrastructure.scientific.stability.check\_numerical\_stability()}, which exercises the same objective with extreme inputs (NaN, \(\pm \infty \), \(\pm 10^{10}\)).}}{14}{figure.caption.13}\protected@file@percent }
\newlabel{fig:stability}{{8}{14}{Numerical stability heatmap from \protect \breaktt {generate\_stability\_visualization()}. Each cell shows \(\log _{10}|f(x)-f(x^\ast )|\) at termination for one (starting point \(x_0\), step size \(\alpha \)) combination, evaluated by \protect \breaktt {gradient\_descent()} over the 8-by-6 grid (48 cells). The leftmost column (\(\alpha =0.01\), conservative) reaches only \(10^{-6}\) to \(10^{-9}\) within the iteration cap, while every other column saturates at machine precision (\(10^{-16}\)) regardless of how far \(x_0\) starts from the optimum (range \([-50, 50]\)). The right panel summarises this uniformity as the aggregate stability score of 1.00/1.00 returned by \protect \breaktt {infrastructure.scientific.stability.check\_numerical\_stability()}, which exercises the same objective with extreme inputs (NaN, \(\pm \infty \), \(\pm 10^{10}\))}{figure.caption.13}{}}
\newlabel{fig:stability@cref}{{[figure][8][]8}{[1][12][]14}{}{}{}}

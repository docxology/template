# Generated outputs and caches are disposable and regeneratable by the pipeline.
# Never commit them (per CLAUDE.md and AGENTS.md). Cleaned by 00_setup_environment.py.
**/output/
**/projects/*/output/
**/.benchmarks/
**/.pytest_cache/
**/.venv/
**/*.egg-info/
**/__pycache__/

# Temporary files
*.tmp
*.temp
*.bak
*.backup

# Test artifacts
invalid/

# projects/: ignore all workspaces except the canonical template exemplars
# (Tracked copies of other projects remain in the index until `git rm -r --cached projects/<name>`.)
# template_code_project and template_prose_project are the two permanent
# always-present exemplars. template_search_project rotates between
# projects/ (active) and projects_archive/; the negation patterns below
# keep it tracked whenever it is restored under projects/.
projects/*
!projects/template_code_project/
!projects/template_code_project/**
!projects/template_prose_project/
!projects/template_prose_project/**
!projects/template_search_project/
!projects/template_search_project/**
projects/*/.DS_Store
projects/*/output/
projects/*/output/**
projects/*/*.egg-info/
projects/*/src/*.egg-info/

# Archived and in-progress projects (not executed by pipeline)
projects_archive/
projects_in_progress/

# Doctor state (infrastructure.doctor) — local backups and audit log
.doctor/


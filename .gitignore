# Temporary files
*.tmp
*.temp
*.bak
*.backup

# Test artifacts
invalid/

# projects/: ignore all workspaces except the canonical template exemplars
# (Tracked copies of other projects remain in the index until `git rm -r --cached projects/<name>`.)
# template_code_project, template_prose_project, and
# template_autoresearch_project are the permanent always-present exemplars.
# template_search_project rotates between projects/ (active) and
# projects_archive/.
projects/*
# CONFIDENTIALITY INVARIANT: this is a PUBLIC repo into which confidential
# projects are routinely rotated under projects/. Repo-level Markdown files in
# projects/ are navigation docs; only the canonical template exemplar
# directories may ever be tracked/pushed. Do NOT add a negation for any other
# project directory (incl. template_search_project) — if a non-confidential
# extra exemplar must be published, update this allowlist and the
# check-tracked-projects guard together. The guard (pre-push + CI) fails the
# build if anything else under projects/ is staged/tracked.
!projects/*.md
!projects/template_code_project/
!projects/template_code_project/**
!projects/template_prose_project/
!projects/template_prose_project/**
!projects/template_active_inference/
!projects/template_active_inference/**
!projects/template_autoresearch_project/
!projects/template_autoresearch_project/**
!projects/template_template/
!projects/template_template/**
projects/*/.DS_Store
projects/*/output/
projects/*/output/**
projects/*/*.egg-info/
projects/*/src/*.egg-info/

# Download/generated fixture payloads. Keep the fixture docs and committed
# private_project stubs visible, but never surface cloned repos or benchmark
# data as accidental untracked source.
tests/fixtures/real_codebases/*
!tests/fixtures/real_codebases/README.md
!tests/fixtures/real_codebases/AGENTS.md
tests/fixtures/timeseries/

# Archived and in-progress projects (not executed by pipeline)
projects_archive/
projects_in_progress/


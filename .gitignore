# Generated outputs and caches are disposable and regeneratable by the pipeline.
# Never commit them (per CLAUDE.md and AGENTS.md). Cleaned by 00_setup_environment.py.
**/output/
**/projects/*/output/
**/.benchmarks/
**/.pytest_cache/
**/.venv/
**/*.egg-info/
**/__pycache__/

# Temporary files
*.tmp
*.temp
*.bak
*.backup

# Test artifacts
invalid/

# projects/: ignore all workspaces except the three canonical template exemplars
# (Tracked copies of other projects remain in the index until `git rm -r --cached projects/<name>`.)
projects/*
!projects/template_code_project/
!projects/template_code_project/**
!projects/template_prose_project/
!projects/template_prose_project/**
!projects/template_search_project/
!projects/template_search_project/**

# Archived and in-progress projects (not executed by pipeline)

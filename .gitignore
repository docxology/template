# Generated outputs and caches are disposable and regeneratable by the pipeline.
# Never commit them (per CLAUDE.md and AGENTS.md). Cleaned by 00_setup_environment.py.
**/output/
# EXCEPTION: `infrastructure/validation/output/` is a SOURCE package
# (validator.py, pipeline.py, no_mock_enforcer.py) whose name collides with
# the generated-output glob above. Without these negations the whole package
# is excluded from version control, so CI's clean checkout cannot
# `import infrastructure.validation.output` — every job that uses it
# (verify-no-mocks, validate, copy, lint's artifact guard) fails with
# ModuleNotFoundError even though it works on a developer's disk.
!infrastructure/validation/output/
!infrastructure/validation/output/**
**/projects/*/output/
# EXCEPTION: the code/prose exemplars' TOP-LEVEL rendered output is tracked
# as living render-proof (a deliberate, scoped reversal of the "never commit
# output" rule above — mirrors the projects/ confidentiality pattern). The
# scripts/check_tracked_generated_artifacts.py guard grants the same paths a
# matching exemption. The AutoResearch exemplar is public, but its top-level
# output stays generated-only unless this allowlist and the guard are updated
# together. Everything else under output/ — including every confidential/active
# project's output (e.g. output/<active-project>/) — stays ignored and is NEVER
# negated here. Leading `/` anchors this to top-level output/ only, so nested
# projects/*/output stays ignored.
!/output/
/output/*
!/output/template_code_project/
!/output/template_code_project/**
!/output/template_prose_project/
!/output/template_prose_project/**
!/output/template_active_inference/
!/output/template_active_inference/**
!/output/template_autoresearch_project/
!/output/template_autoresearch_project/**
!/output/template_template/
!/output/template_template/**
# Public-exemplar PROJECT-LOCAL rendered output (bare-render target) is
# also tracked as render-proof. Scoped to the five public templates only;
# every other projects/*/output stays ignored (confidentiality).
!projects/template_active_inference/output/
!projects/template_active_inference/output/**
!projects/template_autoresearch_project/output/
!projects/template_autoresearch_project/output/**
!projects/template_code_project/output/
!projects/template_code_project/output/**
!projects/template_prose_project/output/
!projects/template_prose_project/output/**
!projects/template_template/output/
!projects/template_template/output/**

output/template_*/**/.checkpoints/
output/template_*/**/.pipeline/
projects/template_*/output/**/.checkpoints/
projects/template_*/output/**/.pipeline/
# Re-exclude LaTeX build-intermediate files inside the tracked public-exemplar
# output trees — keep deliverables (pdf/png/json/csv/html/md), drop churn.
output/template_*/**/*.aux
output/template_*/**/*.log
output/template_*/**/*.out
output/template_*/**/*.toc
output/template_*/**/*.fls
output/template_*/**/*.fdb_latexmk
output/template_*/**/*.snm
output/template_*/**/*.nav
output/template_*/**/*.vrb
output/template_*/**/*.bcf
output/template_*/**/*.run.xml
output/template_*/**/*.synctex.gz
output/template_*/**/*.lof
output/template_*/**/*.lot
output/template_*/**/*.tex
output/template_*/**/*.idx
output/template_*/**/*.ilg
output/template_*/**/*.ind
projects/template_*/output/**/*.aux
projects/template_*/output/**/*.log
projects/template_*/output/**/*.out
projects/template_*/output/**/*.toc
projects/template_*/output/**/*.fls
projects/template_*/output/**/*.fdb_latexmk
projects/template_*/output/**/*.snm
projects/template_*/output/**/*.nav
projects/template_*/output/**/*.vrb
projects/template_*/output/**/*.bcf
projects/template_*/output/**/*.run.xml
projects/template_*/output/**/*.synctex.gz
projects/template_*/output/**/*.lof
projects/template_*/output/**/*.lot
projects/template_*/output/**/*.tex
projects/template_*/output/**/*.idx
projects/template_*/output/**/*.ilg
projects/template_*/output/**/*.ind

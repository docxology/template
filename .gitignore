# Generated outputs and caches are disposable and regeneratable by the pipeline.
# Never commit them (per CLAUDE.md and AGENTS.md). Cleaned by 00_setup_environment.py.
**/output/
# EXCEPTION: `infrastructure/validation/output/` is a SOURCE package
# (validator.py, pipeline.py, no_mock_enforcer.py) whose name collides with
# the generated-output glob above. Without these negations the whole package
# is excluded from version control, so CI's clean checkout cannot
# `import infrastructure.validation.output` — every job that uses it
# (verify-no-mocks, validate, copy, lint's artifact guard) fails with
# ModuleNotFoundError even though it works on a developer's disk.
!infrastructure/validation/output/
!infrastructure/validation/output/**
**/projects/*/output/
# EXCEPTION: the code/prose exemplars' TOP-LEVEL rendered output is tracked
# as living render-proof (a deliberate, scoped reversal of the "never commit
# output" rule above — mirrors the projects/ confidentiality pattern). The
# scripts/check_tracked_generated_artifacts.py guard grants the same paths a
# matching exemption. The AutoResearch exemplar is public, but its top-level
# output stays generated-only unless this allowlist and the guard are updated
# together. Everything else under output/ — including every confidential/active
# project's output (e.g. output/<active-project>/) — stays ignored and is NEVER
# negated here. Leading `/` anchors this to top-level output/ only, so nested
# projects/*/output stays ignored.
!/output/
/output/*
# Public exemplar rendered output lives under output/templates/<name>/ and is
# tracked as living render-proof. Re-include the templates/ shell, then
# re-ignore its contents so ONLY the six canonical exemplars are tracked —
# any other rotating/confidential project's output under output/ stays ignored.
!/output/templates/
/output/templates/*
!/output/templates/template_code_project/
!/output/templates/template_code_project/**
!/output/templates/template_prose_project/
!/output/templates/template_prose_project/**
!/output/templates/template_active_inference/
!/output/templates/template_active_inference/**
!/output/templates/template_autoresearch_project/
!/output/templates/template_autoresearch_project/**
!/output/templates/template_sia/
!/output/templates/template_sia/**
!/output/templates/template_template/
!/output/templates/template_template/**

output/templates/template_*/**/.checkpoints/
output/templates/template_*/**/.pipeline/
# Re-exclude LaTeX build-intermediate files inside the tracked public-exemplar
# output trees — keep deliverables (pdf/png/json/csv/html/md), drop churn.
output/templates/template_*/**/*.aux
output/templates/template_*/**/*.log
output/templates/template_*/**/*.out
output/templates/template_*/**/*.toc
output/templates/template_*/**/*.fls
output/templates/template_*/**/*.fdb_latexmk
output/templates/template_*/**/*.snm
output/templates/template_*/**/*.nav
output/templates/template_*/**/*.vrb
output/templates/template_*/**/*.bcf
output/templates/template_*/**/*.run.xml
output/templates/template_*/**/*.synctex.gz
output/templates/template_*/**/*.lof
output/templates/template_*/**/*.lot
output/templates/template_*/**/*.tex
output/templates/template_*/**/*.idx
output/templates/template_*/**/*.ilg
output/templates/template_*/**/*.ind
**/.benchmarks/
**/.pytest_cache/
**/.venv/
**/*.egg-info/
**/__pycache__/

# Temporary files
*.tmp
*.temp
*.bak
*.backup

# Test artifacts
invalid/

# projects/: typed lifecycle subfolders. Only the canonical public exemplars
# under projects/templates/ are ever tracked; every other typed subfolder
# (active/ working/ published/ archive/ other/) holds private symlinked
# workspaces that must stay LOCAL-ONLY.
projects/*
# CONFIDENTIALITY INVARIANT: this is a PUBLIC repo into which confidential
# projects are routinely rotated under projects/'s typed subfolders. Repo-level
# Markdown files in projects/ are navigation docs; only the six canonical
# template exemplar directories under projects/templates/ may ever be
# tracked/pushed. Do NOT add a negation for any other project directory — if a
# non-confidential extra exemplar must be published, update this allowlist and
# the check-tracked-projects guard together. The guard (pre-push + CI) fails
# the build if anything else under projects/ is staged/tracked.
!projects/*.md
# Re-include the public templates/ subfolder, then re-ignore everything inside
# it so ONLY the canonical exemplars below are ever tracked. Anything else
# dropped into projects/templates/ stays ignored (fail-closed).
!projects/templates/
projects/templates/*
!projects/templates/template_code_project/
!projects/templates/template_code_project/**
!projects/templates/template_prose_project/
!projects/templates/template_prose_project/**
!projects/templates/template_active_inference/
!projects/templates/template_active_inference/**
!projects/templates/template_autoresearch_project/
!projects/templates/template_autoresearch_project/**
!projects/templates/template_sia/
!projects/templates/template_sia/**
!projects/templates/template_template/
!projects/templates/template_template/**
!projects/templates/template_newspaper/
!projects/templates/template_newspaper/**
!projects/templates/template_textbook/
!projects/templates/template_textbook/**
projects/*/.DS_Store
projects/templates/*/.DS_Store
# Exemplar project-local output is a disposable working tree (tracked render-
# proof lives at output/templates/<name>/, not here).
projects/templates/*/output/
projects/templates/*/output/**
projects/*/*.egg-info/
projects/*/src/*.egg-info/
projects/templates/*/*.egg-info/
projects/templates/*/src/*.egg-info/

# Download/generated fixture payloads. Keep the fixture docs and committed
# private_project stubs visible, but never surface cloned repos or benchmark
# data as accidental untracked source.
tests/fixtures/real_codebases/*
!tests/fixtures/real_codebases/README.md
!tests/fixtures/real_codebases/AGENTS.md
tests/fixtures/timeseries/

# Private-projects root override (one-line absolute path; machine-local — must
# never be committed to this public repo). Consumed by
# infrastructure/project/linking.py to locate the sibling docxology/projects repo.
.private_projects_root

# RETIRED top-level mirror dirs (removed; replaced by typed subfolders under
# projects/: active/ working/ published/ archive/ other/). Kept ignored
# defensively so a stray recreation + `git add -A` can never stage private work
# the projects/ guard does not scan.
projects_archive/
projects_in_progress/


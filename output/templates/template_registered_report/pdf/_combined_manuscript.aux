\newlabel{confirmatory-outcome-h1-primary_score}{{5.1}{6}{\texorpdfstring {Confirmatory outcome (H1, \texttt {primary\_score})}{Confirmatory outcome (H1, primary_score)}}{subsection.5.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Registered permutation test on the deterministic demonstration data, rendered by \breaktt {plot\_permutation\_result} from \breaktt {permutation\_null\_distribution} and \breaktt {run\_permutation\_test}. The histogram is the label-permutation null distribution of the treatment-minus-control mean difference (\texttt {2000} seeded shuffles); the solid red line marks the observed difference of \texttt {1.003} and the dotted line its mirror image. The annotation reports \texttt {n\ =\ 24} per group, \texttt {0} shuffles at least as extreme, a two-sided p-value of \texttt {0.0005}, and \texttt {alpha\ =\ 0.05}. The observed statistic sits outside the entire null, which is why the primary confirmatory claim holds.}}{6}{figure.caption.4}\protected@file@percent }
\newlabel{fig:permutation_result}{{3}{6}{Registered permutation test on the deterministic demonstration data, rendered by \protect \breaktt {plot\_permutation\_result} from \protect \breaktt {permutation\_null\_distribution} and \protect \breaktt {run\_permutation\_test}. The histogram is the label-permutation null distribution of the treatment-minus-control mean difference (\protect \texttt {2000} seeded shuffles); the solid red line marks the observed difference of \protect \texttt {1.003} and the dotted line its mirror image. The annotation reports \protect \texttt {n\ =\ 24} per group, \protect \texttt {0} shuffles at least as extreme, a two-sided p-value of \protect \texttt {0.0005}, and \protect \texttt {alpha\ =\ 0.05}. The observed statistic sits outside the entire null, which is why the primary confirmatory claim holds}{figure.caption.4}{}}

\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Registered-report analysis workflow, rendered from \breaktt {analysis\_plan\_stages()} in \breaktt {src/registered\_report/demo\_study.py}. The four blue stages --- freeze registration, validate completeness, collect/simulate data, and execute the registered analysis --- lock before results are revealed (dashed boundary). The two purple stages --- compare to plan and build the deviation ledger, then interpret confirmatory claims --- run only afterwards. The \breaktt {locks\_before\_results} flag on each stage is what enforces the boundary in code.}}{5}{figure.caption.3}\protected@file@percent }
\newlabel{fig:analysis_dag}{{2}{5}{Registered-report analysis workflow, rendered from \protect \breaktt {analysis\_plan\_stages()} in \protect \breaktt {src/registered\_report/demo\_study.py}. The four blue stages --- freeze registration, validate completeness, collect/simulate data, and execute the registered analysis --- lock before results are revealed (dashed boundary). The two purple stages --- compare to plan and build the deviation ledger, then interpret confirmatory claims --- run only afterwards. The \protect \breaktt {locks\_before\_results} flag on each stage is what enforces the boundary in code}{figure.caption.3}{}}

\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Preregistration-versus-executed deviation ledger timeline, rendered by \breaktt {plot\_deviation\_timeline} from \breaktt {build\_deviation\_ledger} and \breaktt {deviation\_timeline}. Each marker is a ledger row coloured by severity: the registered \texttt {primary\_score} outcome is green (\texttt {ok}), while the added \texttt {secondary\_score} endpoint and the \texttt {linear\_model} substitution are amber (\texttt {warning}, documented deviations). No marker is red because every departure carries a rationale. An undocumented departure would appear in red and invalidate the review packet.}}{8}{figure.caption.5}\protected@file@percent }
\newlabel{fig:deviation_timeline}{{4}{8}{Preregistration-versus-executed deviation ledger timeline, rendered by \protect \breaktt {plot\_deviation\_timeline} from \protect \breaktt {build\_deviation\_ledger} and \protect \breaktt {deviation\_timeline}. Each marker is a ledger row coloured by severity: the registered \protect \texttt {primary\_score} outcome is green (\protect \texttt {ok}), while the added \protect \texttt {secondary\_score} endpoint and the \protect \texttt {linear\_model} substitution are amber (\protect \texttt {warning}, documented deviations). No marker is red because every departure carries a rationale. An undocumented departure would appear in red and invalidate the review packet}{figure.caption.5}{}}

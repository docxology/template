\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Structural isomorphism of pregroup grammar derivations across six languages: English, Chinese, Russian, Arabic, Hindi, and Japanese. Each panel shows the same transitive sentence (``SUBJ chases OBJ'') rendered as a DisCoPy string diagram with identical type-logical structure --- n ⊗ (n\^{}r ⊗ s ⊗ n\^{}l) ⊗ n → s --- demonstrating that the categorical type reduction is language-invariant despite surface-level morphosyntactic differences.}}{18}{figure.caption.9}\protected@file@percent }
\newlabel{fig:multilingual-isomorphism}{{6}{18}{Structural isomorphism of pregroup grammar derivations across six languages: English, Chinese, Russian, Arabic, Hindi, and Japanese. Each panel shows the same transitive sentence (``SUBJ chases OBJ'') rendered as a DisCoPy string diagram with identical type-logical structure --- n ⊗ (n\^{}r ⊗ s ⊗ n\^{}l) ⊗ n → s --- demonstrating that the categorical type reduction is language-invariant despite surface-level morphosyntactic differences}{figure.caption.9}{}}
\newlabel{fig:multilingual-isomorphism@cref}{{[figure][6][]6}{[1][17][]18}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces DisCoPy-rendered pregroup grammar diagram for the transitive sentence ``child broke vase,'' produced by the DisCoPy library's native drawing backend. The three Word boxes (child type n, broke type n.r @ s @ n.l, vase type n) are connected by Cup contractions---the leftward cup cancels n with n.r and the rightward cup cancels n.l with n---reducing the entire expression to the sentence type s. The diagrammatic structure makes the type-theoretic derivation immediately inspectable.}}{18}{figure.caption.10}\protected@file@percent }
\newlabel{fig:discopy-transitive}{{7}{18}{DisCoPy-rendered pregroup grammar diagram for the transitive sentence ``child broke vase,'' produced by the DisCoPy library's native drawing backend. The three Word boxes (child type n, broke type n.r @ s @ n.l, vase type n) are connected by Cup contractions---the leftward cup cancels n with n.r and the rightward cup cancels n.l with n---reducing the entire expression to the sentence type s. The diagrammatic structure makes the type-theoretic derivation immediately inspectable}{figure.caption.10}{}}
\newlabel{fig:discopy-transitive@cref}{{[figure][7][]7}{[1][17][]18}{}{}{}}

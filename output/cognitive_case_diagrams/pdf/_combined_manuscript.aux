\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces Three-sentence discourse diagram ``Alice chases Bob. Bob fears Alice. She smiles.'' rendered using DisCoPy's pregroup grammar. The diagram demonstrates case role reversal: Alice is NOM (agent) in sentence 1, ACC (patient) in sentence 2, and NOM again via the anaphoric pronoun ``She'' in sentence 3. Each sentence reduces independently to type s via cup contractions, and the full discourse is the triple tensor product \(s \otimes s \otimes s\). This illustrates how DisCoCirc-style analyses track dynamic case assignment across discourse boundaries.}}{27}{figure.caption.21}\protected@file@percent }
\newlabel{fig:three-sentence-discourse}{{13}{27}{Three-sentence discourse diagram ``Alice chases Bob. Bob fears Alice. She smiles.'' rendered using DisCoPy's pregroup grammar. The diagram demonstrates case role reversal: Alice is NOM (agent) in sentence 1, ACC (patient) in sentence 2, and NOM again via the anaphoric pronoun ``She'' in sentence 3. Each sentence reduces independently to type s via cup contractions, and the full discourse is the triple tensor product \(s \otimes s \otimes s\). This illustrates how DisCoCirc-style analyses track dynamic case assignment across discourse boundaries}{figure.caption.21}{}}
\newlabel{fig:three-sentence-discourse@cref}{{[figure][13][]13}{[1][26][]27}{}{}{}}
